{
  "name": "fovea",
  "version": "0.1.0",
  "description": "Windows-first screenshot question assistant with pluggable AI providers",
  "author": "Fovea contributors",
  "main": "out/main/app.js",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/fetch-codex-sidecar.mjs && electron-builder install-app-deps",
    "sidecar:fetch": "node scripts/fetch-codex-sidecar.mjs",
    "sidecar:smoke": "node scripts/smoke-codex-sidecar.mjs",
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0 && npm run lint:design",
    "lint:design": "node scripts/validate-design-tokens.mjs",
    "assets:generate": "node scripts/generate-assets.mjs",
    "assets:validate": "node scripts/generate-assets.mjs --check",
    "test": "vitest run",
    "build": "electron-vite build",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "eventsource-parser": "^3.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-markdown": "10.1.0",
    "rehype-highlight": "^7.0.2"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.18.3",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "electron-vite": "4.0.0",
    "eslint": "9.35.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "5.9.2",
    "typescript-eslint": "8.43.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  },
  "build": {
    "appId": "com.fovea.desktop",
    "productName": "Fovea",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/sidecar",
        "to": "sidecar",
        "filter": [
          "codex.exe"
        ]
      },
      {
        "from": "resources/licences",
        "to": "licences"
      },
      {
        "from": "resources/assets/generated",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "resources/assets/generated/fovea.ico",
      "artifactName": "Fovea-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "resources/assets/generated/fovea.ico",
      "uninstallerIcon": "resources/assets/generated/fovea.ico"
    }
  }
}
